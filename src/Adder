module Adder (input [3:0] A, B, input Cin, output [3:0] Sum, output Cout, output Overflow);
		wire [2:0] C;
			wire S_MSB;// Most significant bit of the sum
    
		Adder A0 (A[0], B[0], Cin, Sum[0], C[0]);
		Adder A1(A[1], B[1], C[0], Sum[1], C[1]);
		Adder A2(A[2], B[2], C[1], Sum[2], C[2]);
		Adder A3(A[3], B[3], C[2], Sum[3], Cout);

			assign S_MSB = Sum[3];

    
    assign Overflow = (A[3] ^ B[3]) & (S_MSB ^ A[3]);// Overflow detection
endmodule
